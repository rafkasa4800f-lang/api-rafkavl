{
  "name": "brat-canvas",
  "version": "1.0.30",
  "description": "Generate brat-style PNG images with emoji support using @napi-rs/canvas",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/image.js",
      "require": "./dist/cjs/image.cjs"
    },
    "./image": {
      "import": "./dist/esm/image.js",
      "require": "./dist/cjs/image.cjs"
    }
  },
  "files": [
    "dist/",
    "assets/",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "brat",
    "canvas",
    "image",
    "generator",
    "emoji"
  ],
  "author": "Hann Universe",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.44",
    "emoji-db": "^1.0.0"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3"
  },
  "engines": {
    "node": ">=16"
  }
}
